VITE_FIREBASE_DATABASE_URL=https://bayan-portal-bb50e-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=bayan-portal-bb50e
VITE_FIREBASE_STORAGE_BUCKET=bayan-portal-bb50e.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
